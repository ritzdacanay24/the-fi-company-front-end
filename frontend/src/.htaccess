RewriteEngine On
# Redirect /dist/web/request → /request (no-store, no-cache)
RewriteCond %{REQUEST_URI} ^/dist/web/request [NC]
RewriteRule ^dist/web/request(/.*)?$ /request%1 [R=301,L]

<IfModule mod_headers.c>
	# CRITICAL: index.html, ngsw.json, and ngsw-worker.js must NEVER be cached.
	# The Angular service worker checks ngsw.json on every load to detect new versions.
	# If ngsw.json or index.html are cached by the browser, updates are invisible.
	<FilesMatch "^(index\.html|ngsw\.json|ngsw-worker\.js)$">
		Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
		Header always set Pragma "no-cache"
		Header always set Expires "0"
	</FilesMatch>

	# All Angular hashed JS/CSS assets are safe to cache forever (content-hash in filename).
	<FilesMatch "\.(js|css)$">
		Header always set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>

	# No-cache headers for /request
	<If "%{REQUEST_URI} =~ m#^/request#">
		Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
		Header always set Pragma "no-cache"
	</If>
</IfModule>

# If an existing asset or directory is requested go to it as it is
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
RewriteRule ^ - [L]

# If the requested resource doesn't exist, use index.html
RewriteRule ^(.*)$ index.html

