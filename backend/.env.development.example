# Local development defaults (Windows/macOS/Linux with copied driver folder)
QAD_API_COMMAND=npm run dev
NEST_API_COMMAND=npm run dev
NEST_API_PORT=3000
NODE_ENV=development
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=800

QAD_DSN=DEV
QAD_USER=your_qad_user
QAD_PASSWORD=your_qad_password
