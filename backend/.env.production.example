# QAD API Environment Configuration

# Application
NEST_API_COMMAND=npm start
PORT=3000
NODE_ENV=production

# Database (MySQL)
DB_HOST=10.1.0.241
DB_PORT=3306
DB_NAME=eyefidb
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# QAD Configuration
QAD_DSN=Progress OpenEdge Wire Protocol
QAD_USER=your_qad_user
QAD_PASSWORD=your_qad_password

# ODBC Driver Configuration
ODBCINI=/opt1/Progress/DataDirect/Connect64_for_ODBC_71/odbc.ini
ODBCINST=/opt1/Progress/DataDirect/Connect64_for_ODBC_71/odbcinst.ini
LD_LIBRARY_PATH=/opt1/Progress/DataDirect/Connect64_for_ODBC_71/lib

# QAD Driver Path (production path)
QAD_DRIVER_PATH=/opt1/Progress/DataDirect/Connect64_for_ODBC_71
