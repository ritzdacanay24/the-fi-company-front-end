# Local runtime
NEST_API_COMMAND=
PORT=3002
NODE_ENV=production
CHOKIDAR_USEPOLLING=
CHOKIDAR_INTERVAL=
INSPECTION_CHECKLIST_REPORT_GENERATOR_ENABLED=true

# JWT auth
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_EXPIRES_IN=24h

# QAD ODBC
QAD_DSN=Progress OpenEdge Wire Protocol
QAD_USER=your_qad_user
QAD_PASSWORD=your_qad_password
QAD_DSN_DEV=DEV
QAD_USER_DEV=your_qad_user_dev
QAD_PASSWORD_DEV=your_qad_password_dev
QAD_DSN_TEST=TEST
QAD_USER_TEST=your_qad_user_test
QAD_PASSWORD_TEST=your_qad_password_test
QAD_DSN_PROD=Progress OpenEdge Wire Protocol
QAD_USER_PROD=your_qad_user_prod
QAD_PASSWORD_PROD=your_qad_password_prod
QAD_DRIVER_PATH=/var/www/html/backend/qad-driver/Connect64_for_ODBC_71
ODBCINI=/var/www/html/backend/qad-driver/Connect64_for_ODBC_71/odbc.ini
ODBCINST=/var/www/html/backend/qad-driver/Connect64_for_ODBC_71/odbcinst.ini
LD_LIBRARY_PATH=/var/www/html/backend/qad-driver/Connect64_for_ODBC_71/lib

# External MySQL
DB_HOST=10.1.0.241
DB_PORT=3306
DB_NAME=eyefidb
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password

# Local docker mysql service
MYSQL_DATABASE=
MYSQL_ROOT_PASSWORD=

# SMTP (production)
SMTP_HOST=your_smtp_host
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@the-fi-company.com

# Production email routing
DEV_EMAIL_REROUTE_TO=
SCHEDULED_JOB_EMAIL_RECIPIENT_MODE=grouped

# Scheduled jobs
NEST_SCHEDULED_JOBS_ENABLED=true

# IGT transfer distro lists (production)
IGT_TRANSFER_R200_TO=
IGT_TRANSFER_Z024_TO=
IGT_TRANSFER_Z024_CC=
IGT_TRANSFER_LOGO_URL=https://mma.prnewswire.com/media/453980/IGT_Logo.jpg

# Upload root directory target(s), comma-separated if multiple.
# Runtime subfolder is appended by module logic (default: fieldService).
ATTACHMENTS_UPLOAD_ROOT_DIRS=/var/www/html/attachments

# Public URL root returned in attachment links.
# Runtime subfolder is appended by module logic.
ATTACHMENTS_PUBLIC_BASE_URL=https://dashboard.eye-fi.com/attachments

# Bucket-style file storage (production)
MEDIA_STORAGE_MODE=bucket
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_access_key
FILE_STORAGE_S3_PUBLIC_BASE_URL=https://s3.us-west-1.amazonaws.com
FILE_STORAGE_DEFAULT_BUCKET=your-prod-bucket-name

# Optional S3 settings for production testing
# Enable by setting MEDIA_STORAGE_MODE=bucket and FILE_STORAGE_DEFAULT_BUCKET
# AWS_REGION=us-west-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# TomTom Search API key for address lookup
TOMTOM_API_KEY=your_tomtom_api_key

# Company network/VPN CIDR allowlist for PIN login
COMPANY_NETWORK_CIDRS=
