{
  "name": "nest-api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/index.ts\"",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && node scripts/copy-email-templates.js",
    "start": "npm run build && node dist/index.js",
    "logs:tail": "node scripts/tail-log.js latest.log",
    "logs:tail:once": "node scripts/tail-log.js latest.log --once"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/schedule": "^5.0.1",
    "@types/compression": "^1.8.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cron": "^4.4.0",
    "handlebars": "^4.7.9",
    "joi": "^17.13.3",
    "mysql2": "^3.11.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.0",
    "odbc": "^2.4.9",
    "pdfkit": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.13.8",
    "@types/ws": "^8.5.16",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
