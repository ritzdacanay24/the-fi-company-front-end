<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; color: #1f2933;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 900px; background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; overflow: hidden;">
            {{> email-header}}
            <tr>
              <td style="padding: 20px 24px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">Action Needed on Field Service Open Work Orders</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; font-size: 14px; line-height: 1.6;">
                <p style="margin: 0 0 10px 0;"><strong>Total overdue work orders:</strong> {{totalOverdue}}</p>
                <p style="margin: 0 0 16px 0;">This report is generated daily at 9am. These orders need immediate action and should be closed if complete.</p>

                {{#if hasRows}}
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse: collapse; margin-bottom: 18px;">
                  <thead>
                    <tr>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">FSID</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Ticket #</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Ticket Created On</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Status</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Service Type</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Customer</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Property</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Sign Theme</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Installers</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Age</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each rows}}
                    <tr>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{fsSchedulerId}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{ticketId}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{createdDate}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{status}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{serviceType}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{customer}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{property}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{signTheme}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{installers}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{age}}</td>
                    </tr>
                    {{/each}}
                  </tbody>
                </table>
                {{else}}
                <p style="margin: 0 0 16px 0; color: #15803d; font-weight: 600;">No overdue field service open work orders found.</p>
                {{/if}}
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
