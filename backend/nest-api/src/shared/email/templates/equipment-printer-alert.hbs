<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; color: #1f2933;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 920px; background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; overflow: hidden;">
            {{> email-header}}
            <tr>
              <td style="padding: 20px 24px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">Printer Supply/Status Alert</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; font-size: 14px; line-height: 1.6;">
                <p style="margin: 0 0 16px 0;">Detected {{totalCount}} printer issue(s): {{criticalCount}} critical, {{warningCount}} warning.</p>

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse: collapse; font-size: 13px;">
                  <thead>
                    <tr>
                      <th align="left" style="padding: 8px; border-bottom: 2px solid #d1d5db; background: #f8fafc;">Model</th>
                      <th align="left" style="padding: 8px; border-bottom: 2px solid #d1d5db; background: #f8fafc;">Location</th>
                      <th align="left" style="padding: 8px; border-bottom: 2px solid #d1d5db; background: #f8fafc;">IP</th>
                      <th align="left" style="padding: 8px; border-bottom: 2px solid #d1d5db; background: #f8fafc;">Severity</th>
                      <th align="left" style="padding: 8px; border-bottom: 2px solid #d1d5db; background: #f8fafc;">Issue</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each issues}}
                    <tr>
                      <td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">{{model}}</td>
                      <td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">{{location}}</td>
                      <td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">{{ipAddress}}</td>
                      <td style="padding: 8px; border-bottom: 1px solid #e5e7eb; font-weight: 600; text-transform: uppercase; color: {{#if isCritical}}#b91c1c{{else}}#92400e{{/if}};">{{severity}}</td>
                      <td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">
                        <div style="margin-bottom: 6px;">{{message}}</div>
                        {{#if hasLevelPercent}}
                        <div style="max-width: 260px;">
                          <div style="height: 8px; background: #e5e7eb; border-radius: 999px; overflow: hidden;">
                            <div style="height: 8px; width: {{levelPercent}}%; background: {{levelBarColor}};"></div>
                          </div>
                          <div style="margin-top: 4px; font-size: 12px; color: #4b5563;">{{levelPercent}}% remaining</div>
                        </div>
                        {{/if}}
                      </td>
                    </tr>
                    {{/each}}
                  </tbody>
                </table>
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
