<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f5f5f5; color: #222222;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 8px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; background-color: #ffffff; border: 1px solid #d8d8d8;">
            {{> email-header}}
            <tr>
              <td style="padding: 12px 16px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">IGT Transfer Notification</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 14px 16px; font-size: 14px; line-height: 1.4;">
                <p style="margin: 0 0 10px 0;">Hello,</p>

                {{#if isReno}}
                <p style="margin: 0 0 10px 0;">Attached transfer for above referenced sign, shipping to Reno tonight.</p>
                {{else}}
                <p style="margin: 0 0 10px 0;">Attached transfer for above referenced sign, being transferred to Field Service today.</p>
                {{/if}}

                {{#if hasSoDueRows}}
                <table border="1" cellpadding="0" cellspacing="0" width="100%" style="border-collapse: collapse; margin: 8px 0; width: 100%; font-family: Arial, sans-serif; font-size: 14px; line-height: 1.15;">
                  <thead>
                    <tr style="background-color: #ffffff; color: #222222;">
                      <th style="padding: 3px 5px; text-align: left; line-height: 1.15; border: 1px solid #bbbbbb;">SO Number</th>
                      <th style="padding: 3px 5px; text-align: left; line-height: 1.15; border: 1px solid #bbbbbb;">Line #</th>
                      <th style="padding: 3px 5px; text-align: left; line-height: 1.15; border: 1px solid #bbbbbb;">Due Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each soDueRows}}
                    <tr style="background-color: #ffffff;">
                      <td style="padding: 3px 5px; border: 1px solid #d0d0d0; line-height: 1.15;">{{so_number}}</td>
                      <td style="padding: 3px 5px; border: 1px solid #d0d0d0; line-height: 1.15;">{{so_line}}</td>
                      <td style="padding: 3px 5px; border: 1px solid #d0d0d0; line-height: 1.15;">{{due_date}}</td>
                    </tr>
                    {{/each}}
                  </tbody>
                </table>
                {{/if}}

                <p style="margin: 8px 0 4px 0;">Review this transfer in Dashboard:</p>
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 0;">
                  <tr>
                    <td align="left" bgcolor="#0b5cab" style="mso-padding-alt: 6px 10px;">
                      <!--[if mso]>
                      <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" href="{{editUrl}}" style="height:30px;v-text-anchor:middle;width:145px;" arcsize="4%" stroke="f" fillcolor="#0b5cab">
                        <w:anchorlock/>
                        <center style="color:#ffffff;font-family:Arial, Helvetica, sans-serif;font-size:13px;font-weight:600;">Open IGT Transfer</center>
                      </v:roundrect>
                      <![endif]-->
                      <!--[if !mso]><!-- -->
                      <a
                        href="{{editUrl}}"
                        style="display: inline-block; min-width: 145px; padding: 6px 10px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; font-weight: 600; line-height: 1.2; text-align: center; white-space: nowrap; color: #ffffff; text-decoration: none; background-color: #0b5cab; border: 1px solid #0b5cab;"
                      >Open IGT Transfer</a>
                      <!--<![endif]-->
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
