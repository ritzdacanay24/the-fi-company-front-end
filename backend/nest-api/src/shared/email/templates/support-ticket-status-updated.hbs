<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; color: #1f2933;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; overflow: hidden;">
            {{> email-header}}
            <tr>
              <td style="padding: 20px 24px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">Support Ticket Status Updated</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; font-size: 14px; line-height: 1.6;">
                <p style="margin-top: 0;">The status of your support ticket has been updated.</p>
                <p style="margin: 0 0 10px 0;"><strong>Ticket #:</strong> {{ticketNumber}}</p>
                <p style="margin: 0 0 16px 0;"><strong>Title:</strong> {{title}}</p>
                <table role="presentation" cellspacing="0" cellpadding="0" style="margin: 0 0 20px 0; font-size: 14px;">
                  <tr>
                    <td style="padding: 8px 12px; background-color: #f5f7fa; border: 1px solid #dde3ea; border-radius: 4px 0 0 4px; color: #5a6b7b;">
                      Previous Status
                    </td>
                    <td style="padding: 8px 12px; background-color: #f5f7fa; border: 1px solid #dde3ea; border-left: none; font-weight: 600;">
                      {{previousStatus}}
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 8px 12px; background-color: #eef6ff; border: 1px solid #dde3ea; border-top: none; border-radius: 0 0 0 4px; color: #5a6b7b;">
                      New Status
                    </td>
                    <td style="padding: 8px 12px; background-color: #eef6ff; border: 1px solid #dde3ea; border-top: none; border-left: none; border-radius: 0 0 4px 0; font-weight: 600; color: #0b5cab;">
                      {{newStatus}}
                    </td>
                  </tr>
                </table>
                {{#if link}}
                <p style="margin: 0 0 24px 0;">
                  <a href="{{link}}" style="display: inline-block; padding: 10px 18px; border-radius: 6px; background-color: #0b5cab; color: #ffffff; text-decoration: none; font-weight: 600;">
                    View Ticket
                  </a>
                </p>
                {{/if}}
                <p style="margin: 0; color: #5a6b7b; font-size: 12px;">Please do not reply to this email. This is an automated message from The Fi Company Dashboard.</p>
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
