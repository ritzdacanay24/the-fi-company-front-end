<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; color: #1f2933;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; overflow: hidden;">
            {{> email-header}}
            <tr>
              <td style="padding: 20px 24px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">Parts Order Request</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; font-size: 14px; line-height: 1.6;">
                <p style="margin-top: 0;">A new parts order request was submitted.</p>
                {{#if soNumber}}<p style="margin: 0 0 6px 0;"><strong>SV Number:</strong> {{soNumber}}</p>{{/if}}
                <p style="margin: 0 0 6px 0;"><strong>Parts Order ID:</strong> {{id}}</p>
                <p style="margin: 0 0 6px 0;"><strong>OEM:</strong> {{oem}}</p>
                <p style="margin: 0 0 6px 0;"><strong>Casino Name:</strong> {{casinoName}}</p>
                <p style="margin: 0 0 6px 0;"><strong>Arrival Date:</strong> {{arrivalDate}}</p>
                <p style="margin: 0 0 6px 0;"><strong>Address:</strong> {{address}}</p>
                <p style="margin: 0 0 6px 0;"><strong>Contact:</strong> {{contactName}}</p>
                <p style="margin: 0 0 16px 0;"><strong>Contact Phone Number:</strong> {{contactPhone}}</p>

                {{#if instructions}}
                <p style="margin: 0 0 16px 0;"><strong>Instructions:</strong> {{instructions}}</p>
                {{/if}}

                {{#if hasDetails}}
                <p style="margin: 0 0 8px 0;"><strong>Parts</strong></p>
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse: collapse; margin-bottom: 16px;">
                  <thead>
                    <tr>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Part Number</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Billable</th>
                      <th align="left" style="border: 1px solid #dde3ea; padding: 8px; background: #f8fafc;">Qty</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each details}}
                    <tr>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{this.partNumber}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{this.billable}}</td>
                      <td style="border: 1px solid #dde3ea; padding: 8px;">{{this.qty}}</td>
                    </tr>
                    {{/each}}
                  </tbody>
                </table>
                {{/if}}

                <p style="margin: 0 0 24px 0;">
                  <a href="{{link}}" style="display: inline-block; padding: 10px 18px; border-radius: 6px; background-color: #0b5cab; color: #ffffff; text-decoration: none; font-weight: 600;">
                    View Parts Order Request
                  </a>
                </p>
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
