<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; color: #1f2933;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; overflow: hidden;">
            {{> email-header}}
            <tr>
              <td style="padding: 20px 24px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">Training Session Cancelled</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; font-size: 14px; line-height: 1.6;">
                <p style="margin-top: 0;">Hello {{fullName}},</p>
                <div style="margin: 0 0 16px 0; padding: 10px 12px; border-left: 4px solid #dc2626; background-color: #fef2f2; color: #991b1b; border-radius: 6px;">
                  This training session has been cancelled.
                </div>
                <p>The following training session has been cancelled:</p>
                <p style="margin: 0 0 10px 0;"><strong>Session:</strong> {{title}}</p>
                <p style="margin: 0 0 10px 0;"><strong>Date:</strong> {{date}}</p>
                <p style="margin: 0 0 10px 0;"><strong>Time:</strong> {{startTime}} - {{endTime}}</p>
                <p style="margin: 0 0 16px 0;"><strong>Location:</strong> {{location}}</p>
                <p style="margin: 0;">Please contact the training coordinator if you have any questions.</p>
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>