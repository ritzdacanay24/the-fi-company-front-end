<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; color: #1f2933;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; overflow: hidden;">
            {{> email-header}}
            <tr>
              <td style="padding: 20px 24px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">New QIR Submitted</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; font-size: 14px; line-height: 1.6;">
                <p style="margin-top: 0;">A new Quality Inspection Report was submitted.</p>
                <p style="margin: 0 0 10px 0;"><strong>QIR Number:</strong> {{qirId}}</p>
                <p style="margin: 0 0 16px 0;"><strong>Created Date:</strong> {{createdDate}}</p>

                {{#if stakeholder}}
                <p style="margin: 0 0 8px 0;"><strong>Stakeholder:</strong> {{stakeholder}}</p>
                {{/if}}
                {{#if failureType}}
                <p style="margin: 0 0 8px 0;"><strong>Failure Type:</strong> {{failureType}}</p>
                {{/if}}
                {{#if customerName}}
                <p style="margin: 0 0 8px 0;"><strong>Customer Name:</strong> {{customerName}}</p>
                {{/if}}
                {{#if componentType}}
                <p style="margin: 0 0 8px 0;"><strong>Component Type:</strong> {{componentType}}</p>
                {{/if}}
                {{#if type1}}
                <p style="margin: 0 0 8px 0;"><strong>Type:</strong> {{type1}}</p>
                {{/if}}
                {{#if eyefiPartNumber}}
                <p style="margin: 0 0 8px 0;"><strong>Part Number:</strong> {{eyefiPartNumber}}</p>
                {{/if}}
                {{#if qtyAffected}}
                <p style="margin: 0 0 8px 0;"><strong>Qty Affected:</strong> {{qtyAffected}}</p>
                {{/if}}
                {{#if priority}}
                <p style="margin: 0 0 16px 0;"><strong>Severity:</strong> {{priority}}</p>
                {{/if}}

                {{#if issueComment}}
                <p style="margin: 0 0 8px 0;"><strong>Issue Statement:</strong></p>
                <p style="margin: 0 0 20px 0; background-color: #f5f7fa; border-left: 4px solid #cfd8e3; padding: 10px;">{{issueComment}}</p>
                {{/if}}

                <p style="margin: 0 0 24px 0;">
                  <a href="{{link}}" style="display: inline-block; padding: 10px 18px; border-radius: 6px; background-color: #0b5cab; color: #ffffff; text-decoration: none; font-weight: 600;">
                    View QIR
                  </a>
                </p>

                <p style="margin: 0; color: #5a6b7b; font-size: 12px;">Please do not reply to this email. This is an automated message from The Fi Company Dashboard.</p>
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
