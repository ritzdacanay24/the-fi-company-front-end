<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; color: #1f2933;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; overflow: hidden;">
            {{> email-header}}
            <tr>
              <td style="padding: 20px 24px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">🔔 Comment Reminder</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; font-size: 14px; line-height: 1.6;">
                <p style="margin-top: 0;">Hi {{userName}},</p>
                <p style="margin: 0 0 16px 0;">
                  You set a reminder for a comment on <strong>{{commentType}} {{orderNum}}</strong>.
                </p>
                <p style="margin: 0 0 8px 0;"><strong>Reminder Time:</strong> {{remindAt}}</p>
                {{#if note}}
                <p style="margin: 0 0 12px 0;"><strong>Your Note:</strong> {{note}}</p>
                {{/if}}
                <p style="margin: 0 0 8px 0;"><strong>Comment:</strong></p>
                <p style="margin: 0 0 20px 0; background-color: #f5f7fa; border-left: 4px solid #0b5cab; padding: 10px; white-space: pre-wrap;">{{commentText}}</p>

                {{#if commentUrl}}
                <p style="margin: 0 0 24px 0;">
                  <a href="{{commentUrl}}" style="display: inline-block; padding: 10px 18px; border-radius: 6px; background-color: #0b5cab; color: #ffffff; text-decoration: none; font-weight: 600;">
                    Open Comment
                  </a>
                </p>
                {{/if}}

                <p style="margin: 0; color: #5a6b7b; font-size: 12px;">
                  This is an automated reminder from The Fi Company Dashboard.
                </p>
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
