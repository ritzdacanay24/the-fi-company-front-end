<html>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; color: #1f2933;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; overflow: hidden;">
            {{> email-header}}
            <tr>
              <td style="padding: 20px 24px; background-color: #0b5cab; color: #ffffff;">
                <h2 style="margin: 0; font-size: 20px; font-weight: 600;">Field Service Job Report</h2>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px; font-size: 14px; line-height: 1.6;">
                <p style="margin-top: 0;">Hello Team,</p>
                <p style="margin: 0 0 16px 0;">Please find attached the Field Service job report for the following period:</p>
                <p style="margin: 0 0 10px 0;"><strong>Report Period:</strong> {{monthStart}} to {{monthEnd}}</p>
                <p style="margin: 0 0 16px 0;">The attached CSV file contains detailed information about all scheduled field service jobs during this period.</p>
                <p style="margin: 0 0 24px 0;">If you have any questions or need clarification, please reach out to the operations team.</p>
                {{#if recipientCount}}
                <p style="margin: 0; color: #5a6b7b; font-size: 12px;">This report was sent to {{recipientCount}} recipient(s).</p>
                {{/if}}
              </td>
            </tr>
            {{> email-footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
