ErrorDocument 404 /error/404.html
ErrorDocument 403 /error/403.html

RewriteEngine On

# Redirect legacy /portal/web/ and /dist/web/ links to clean root
RedirectMatch ^/portal(/.*)?$ https://dashboard.eye-fi.com/
RewriteRule ^dist/web/request/?$ /request [R=301,L,E=NO_CACHE:1]
RewriteRule ^dist/web/menu/?$ /menu [R=302,L]
RewriteRule ^dist/web/(.*)$ /frontend/$1 [R=301,L]

# Prevent caching of the request redirect so clients pick up route changes immediately
Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=NO_CACHE
Header always set Pragma "no-cache" env=NO_CACHE
Header always set Expires "0" env=NO_CACHE

# Serve frontend index.html at root
RewriteRule ^$ /frontend/index.html [L]

# Transparently serve Angular assets from frontend/ if the file exists there
RewriteCond %{DOCUMENT_ROOT}/frontend/$1 -f
RewriteRule ^(.+)$ /frontend/$1 [L]

# Angular deep-link fallback: unknown paths not matching backend serve frontend index
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(server|api|tasks|attachments|dist|downloads|frontend)/
RewriteRule ^ /frontend/index.html [L]

# Block access to sensitive directories
RewriteRule ^(?!(dist|server|tasks|frontend|attachments|attachments_mount|index\.php|favicon\.ico)(/|$)|$) - [F,L]

# Block sensitive files regardless of rewrite order
<FilesMatch "(^\.env|^\.git|composer\.(json|lock)$|docker-compose\.yml$|php\.ini$|PHP_errors\.log$|\.sql$|\.md$|\.sh$|\.conf$)">
    Require all denied
</FilesMatch>

RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
SetEnvIf Authorization .+ HTTP_AUTHORIZATION=$0

# PHP catch-all for backend routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

IndexIgnore *
Options -Indexes

# supress php errors
php_flag display_startup_errors off
php_flag display_errors off
php_flag html_errors off

# enable PHP error logging
php_flag  log_errors on

php_value error_log  /var/www/html/PHP_errors.log

php_value auto_prepend_file /var/www/config/.loader.php

php_value memory_limit -1
